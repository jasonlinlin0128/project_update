rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 任何人可讀所有資料（公開儀表板需要）
    match /{document=**} {
      allow read: if true;
    }

    // 管理資料：只有登入者可寫
    match /projects/{doc} { allow write: if request.auth != null; }
    match /routines/{doc} { allow write: if request.auth != null; }
    match /meetings/{doc} { allow write: if request.auth != null; }
    match /forums/{doc} { allow write: if request.auth != null; }
    match /events/{doc} { allow write: if request.auth != null; }
    match /coordination/{doc} { allow write: if request.auth != null; }

    // 完成紀錄：不需登入（個人追蹤工具）
    match /routine_completions/{doc} {
      allow read, write: if true;
    }
  }
}
